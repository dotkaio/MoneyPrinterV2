{
  "dataDirectory": "./data",
  "logLevel": "info",
  "browser": {
    "headless": false
  },
  "authentication": {
    "keychainService": "com.kaio.moneyprinterv2.auth"
  },
  "providers": {
    "llm": {
      "kind": "ollama",
      "baseUrl": "http://127.0.0.1:11434",
      "model": ""
    },
    "image": {
      "kind": "gemini",
      "baseUrl": "https://generativelanguage.googleapis.com/v1beta",
      "model": "gemini-3.1-flash-image",
      "apiKeyEnv": "GEMINI_API_KEY",
      "aspectRatio": "9:16"
    },
    "tts": {
      "kind": "piper",
      "executable": "piper",
      "modelPath": ""
    },
    "transcription": {
      "kind": "whisper-cpp",
      "executable": "whisper-cli",
      "modelPath": ""
    }
  },
  "media": {
    "ffmpegPath": "ffmpeg",
    "ffprobePath": "ffprobe",
    "width": 1080,
    "height": 1920,
    "framesPerSecond": 30,
    "minimumScenes": 4,
    "maximumScenes": 12,
    "backgroundMusicVolume": 0.1
  },
  "publishers": {
    "youtube": {
      "clientIdEnv": "YOUTUBE_CLIENT_ID",
      "clientSecretEnv": "YOUTUBE_CLIENT_SECRET",
      "redirectUri": "http://127.0.0.1:53682/oauth2/callback",
      "uploadBaseUrl": "https://www.googleapis.com/upload/youtube/v3/videos"
    },
    "twitter": {
      "baseUrl": "https://x.com"
    },
    "bluesky": {
      "serviceUrl": "https://bsky.social"
    },
    "linkedin": {
      "clientIdEnv": "LINKEDIN_CLIENT_ID",
      "clientSecretEnv": "LINKEDIN_CLIENT_SECRET",
      "redirectUri": "http://127.0.0.1:53682/oauth2/linkedin",
      "authorizationUrl": "https://www.linkedin.com/oauth/v2/authorization",
      "tokenUrl": "https://www.linkedin.com/oauth/v2/accessToken",
      "apiBaseUrl": "https://api.linkedin.com",
      "apiVersion": "202605",
      "scopes": ["openid", "profile", "w_member_social"]
    },
    "tiktok": {
      "clientIdEnv": "TIKTOK_CLIENT_KEY",
      "clientSecretEnv": "TIKTOK_CLIENT_SECRET",
      "redirectUri": "https://example.com/oauth2/tiktok",
      "authorizationUrl": "https://www.tiktok.com/v2/auth/authorize/",
      "tokenUrl": "https://open.tiktokapis.com/v2/oauth/token/",
      "scopes": ["user.info.basic", "video.publish", "video.upload"]
    },
    "meta": {
      "clientIdEnv": "META_APP_ID",
      "clientSecretEnv": "META_APP_SECRET",
      "redirectUri": "https://example.com/oauth2/meta",
      "authorizationUrl": "https://www.facebook.com/dialog/oauth",
      "tokenUrl": "https://graph.facebook.com/oauth/access_token",
      "scopes": [
        "pages_show_list",
        "pages_read_engagement",
        "pages_manage_posts",
        "instagram_basic",
        "instagram_content_publish"
      ]
    }
  },
  "outreach": {
    "scraperExecutable": "google-maps-scraper",
    "scraperTimeoutMs": 300000,
    "websiteTimeoutMs": 15000,
    "maximumWebsiteBytes": 2000000,
    "sendDelayMs": 10000,
    "smtp": {
      "host": "smtp.gmail.com",
      "port": 587,
      "secure": false,
      "usernameEnv": "SMTP_USERNAME",
      "passwordEnv": "SMTP_PASSWORD",
      "fromEnv": "SMTP_FROM"
    }
  },
  "worker": {
    "pollIntervalMs": 1000,
    "leaseDurationMs": 300000,
    "maximumAttempts": 3
  },
  "safety": {
    "livePublishing": false,
    "outreachSending": false,
    "outreachDailyLimit": 25,
    "outreachPerDomainLimit": 1
  }
}
