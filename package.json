{
  "name": "moneyprinterv2",
  "version": "3.0.0-alpha.1",
  "private": true,
  "description": "Standalone local-first AI content studio and publishing workspace",
  "author": "MoneyPrinter contributors",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/desktop/main.js",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=24 <27"
  },
  "bin": {
    "moneyprinter": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "pnpm interface:build:web",
    "compile": "pnpm interface:build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit && tsc -p src/interface/web/tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "mpv2": "tsx src/cli/index.ts",
    "interface": "pnpm interface:build && tsx src/cli/index.ts interface",
    "interface:build": "vite build",
    "interface:build:web": "vite build --mode web",
    "interface:dev": "vite",
    "desktop": "pnpm desktop:package && open release/mac-arm64/MoneyPrinter.app",
    "desktop:package": "pnpm compile && tsx src/desktop/build-desktop.ts --mac --dir",
    "desktop:dist": "pnpm compile && tsx src/desktop/build-desktop.ts --mac dmg zip",
    "worker": "tsx src/worker/index.ts",
    "start": "node dist/cli/index.js",
    "worker:compiled": "node dist/worker/index.js"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^15.0.0",
    "croner": "^10.0.1",
    "csv-parse": "^7.0.1",
    "drizzle-orm": "^0.45.2",
    "execa": "^9.6.1",
    "google-auth-library": "^10.9.0",
    "lucide-react": "^1.24.0",
    "nodemailer": "^9.0.3",
    "ollama": "^0.6.3",
    "pino": "^10.3.1",
    "playwright": "^1.61.1",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "shadcn": "^4.13.0",
    "sharp": "^0.35.3",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.kaio.moneyprinter",
    "productName": "MoneyPrinter",
    "artifactName": "MoneyPrinter-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*.js",
      "dist/**/*.js.map",
      "!dist/interface-web{,/**/*}",
      "migrations/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/interface-web",
        "to": "interface-web"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/sharp/**/*"
    ],
    "npmRebuild": true,
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
